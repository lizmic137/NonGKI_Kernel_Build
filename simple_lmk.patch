diff --git a/mm/page_alloc.c b/mm/page_alloc.c
index 5672fe3c9352..1fa121b2ec70 100755
--- a/mm/page_alloc.c
+++ b/mm/page_alloc.c
@@ -3692,6 +3692,8 @@ __alloc_pages_slowpath(gfp_t gfp_mask, unsigned int order,
