CONFIG_ENV=Profiles/polaris_pe_a13.env

DEVICE_NAME=xiaomi_mix2s_cn
DEVICE_CODENAME=polaris

CUSTOM_CMDS:CLANG_TRIPLE=aarch64-linux-gnu-
EXTRA_CMDS:LD=ld.lld

KERNEL_SOURCE=https://github.com/lizmic137/kernel_xiaomi_polaris.git
KERNEL_BRANCH=thirteen
CLANG_SOURCE=https://github.com/kdrag0n/proton-clang.git
CLANG_BRANCH=master

GCC_64_SOURCE=https://github.com/JackA1ltman/Google-GCC-Android-4.9.git
GCC_64_BRANCH=aarch64
GCC_32_SOURCE=https://github.com/JackA1ltman/Google-GCC-Android-4.9.git
GCC_32_BRANCH=arm32

DEFCONFIG_SOURCE=
DEFCONFIG_NAME=polaris_defconfig

KERNELSU_SOURCE=https://github.com/KernelSU-Next/KernelSU-Next.git
KERNELSU_BRANCH=next
KERNELSU_NAME=KernelSU-Next

SUSFS_ENABLE=false
SUSFS_FIXED=false

AK3_SOURCE=
AK3_BRANCH=

BOOT_SOURCE=https://gitlab.com/linggou/prelude-clang/-/raw/master/boot.img
LXC_ENABLE=false

ROM_TEXT=pe_android13
