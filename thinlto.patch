diff --git a/Makefile b/Makefile
index 3d5c1c7..a8f2a0d 100644
--- a/Makefile
+++ b/Makefile
@@ -993,6 +993,12 @@ KBUILD_CFLAGS	+= $(call cc-disable-warning, address-of-packed-member)
 KBUILD_CFLAGS	+= $(call cc-disable-warning, attribute-alias)
 
 ifdef CONFIG_LD_DEAD_CODE_DATA_ELIMINATION
+ifdef CONFIG_LTO_CLANG
+# Disable LTO for dead code elimination to avoid conflicts
+KBUILD_CFLAGS	+= $(DISABLE_LTO_CLANG)
+else
 KBUILD_CFLAGS	+= $(call cc-option,-ffunction-sections,)
 KBUILD_CFLAGS	+= $(call cc-option,-fdata-sections,)
 endif
+endif
 
 ifdef CONFIG_LTO_CLANG
@@ -1000,6 +1006,16 @@ ifdef CONFIG_LTO_CLANG
 # use GNU gold with LLVMgold for LTO linking, and LD for vmlinux_link
 LDFINAL_vmlinux := $(LD)
 LD		:= $(LDGOLD)
+ifdef CONFIG_THINLTO
+    lto-clang-flags	:= -flto=thin -fsplit-lto-unit
+    KBUILD_LDFLAGS += --thinlto-cache-dir=$(extmod-prefix).thinlto-cache
+else
+    lto-clang-flags	:= -flto
+endif
+lto-clang-flags	+= -fvisibility=default
+
+# Limit cross-module inlining
+LD_FLAGS_LTO_CLANG := -mllvm -import-instr-limit=5
 LDFLAGS		+= -plugin LLVMgold.so
 # use llvm-ar for building symbol tables from IR files, and llvm-dis instead
 # of objdump for processing symbol versions and exports
@@ -1009,7 +1025,7 @@ export LLVM_AR LLVM_DIS
 endif
 
 ifdef CONFIG_LTO_CLANG
-lto-clang-flags	:= -flto -fvisibility=hidden
+lto-clang-flags	?= -flto -fvisibility=hidden
 
 # allow disabling only clang LTO where needed
 DISABLE_LTO_CLANG := -fno-lto -fvisibility=default
@@ -1019,6 +1035,9 @@ ifdef CONFIG_LTO
 lto-flags	:= $(lto-clang-flags)
 KBUILD_CFLAGS	+= $(lto-flags)
 
+KBUILD_LDFLAGS += $(LD_FLAGS_LTO_CLANG)
+KBUILD_LDFLAGS_MODULE += $(LD_FLAGS_LTO_CLANG)
+
 DISABLE_LTO	:= $(DISABLE_LTO_CLANG)
 export DISABLE_LTO
 
@@ -1029,6 +1048,10 @@ export LDFINAL_vmlinux LDFLAGS_FINAL_vmlinux
 endif
 KBUILD_CFLAGS += -O3
 KBUILD_LDFLAGS += --lto-O3
+
+# Define external module prefix for ThinLTO cache
+extmod-prefix = $(if $(KBUILD_EXTMOD),$(KBUILD_EXTMOD)/)
+
 ifdef CONFIG_CC_WERROR
 KBUILD_CFLAGS	+= -Werror
 endif
