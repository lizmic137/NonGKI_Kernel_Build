diff --git a/drivers/net/wireguard/ratelimiter.c b/drivers/net/wireguard/ratelimiter.c
index 1a2b3f4..d3b2e6a 100644
--- a/drivers/net/wireguard/ratelimiter.c
+++ b/drivers/net/wireguard/ratelimiter.c
@@ -20,6 +20,7 @@
 #include "ratelimiter.h"
 #include <linux/siphash.h>
 #include <linux/mm.h>
+#include <linux/sysinfo.h>
 #include <linux/slab.h>
 #include <net/ip.h>
 
@@ -166,6 +167,8 @@ int wg_ratelimiter_init(void)
 {
 	mutex_lock(&init_lock);
 	if (++init_refcnt != 1)
+	struct sysinfo si;
+	unsigned long totalram_pgs;
 		goto out;
 
 	entry_cache = KMEM_CACHE(ratelimiter_entry, 0);
@@ -174,6 +177,9 @@ int wg_ratelimiter_init(void)
 
 	/* xt_hashlimit.c uses a slightly different algorithm for ratelimiting,
 	 * but what it shares in common is that it uses a massive hashtable. So,
+	si_meminfo(&si);
+	totalram_pgs = si.totalram;
+
 	 * we borrow their wisdom about good table sizes on different systems
 	 * dependent on RAM. This calculation here comes from there.
 	 */
-	table_size = (totalram_pages() > (1U << 30) / PAGE_SIZE) ? 8192 :
+	table_size = (totalram_pgs > (1U << 30) / PAGE_SIZE) ? 8192 :
 		max_t(unsigned long, 16, roundup_pow_of_two(
-			(totalram_pages() << PAGE_SHIFT) /
+			(totalram_pgs << PAGE_SHIFT) /
 			(1U << 14) / sizeof(struct hlist_head)));
 	max_entries = table_size * 8;
