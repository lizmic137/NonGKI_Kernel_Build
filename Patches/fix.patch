From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: Your Name <your.email@example.com>
Date: Mon, 20 May 2025 15:45:00 +0800
Subject: [PATCH] Replace VM_LOWMEM with VM_MAP in vmalloc.c

This works around the missing VM_LOWMEM definition

Signed-off-by: Your Name <your.email@example.com>
---
 mm/vmalloc.c | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/mm/vmalloc.c b/mm/vmalloc.c
index 7aad09b65..40292b158 100644
--- a/mm/vmalloc.c
+++ b/mm/vmalloc.c
@@ -3446,7 +3446,7 @@ static void vmap_debug_free_range(unsigned long start, unsigned long end)
 #ifdef CONFIG_KPM
 static void free_unmap_vmap_area(struct vmap_area *va)
 {
-	if (v->flags & VM_LOWMEM)
+	if (v->flags & VM_MAP)  /* 使用现有的 VM_MAP 标志 */
 		kpm_free_page(addr, size);
 	else
 		vunmap_page_range(addr, addr + size);
-- 
2.39.2
